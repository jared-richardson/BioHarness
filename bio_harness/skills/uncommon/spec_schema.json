{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Uncommon Skill Catalog",
  "type": "object",
  "required": ["version", "skills"],
  "properties": {
    "version": {"type": "integer", "minimum": 1},
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "description",
          "risk_level",
          "capabilities",
          "tools_required",
          "parameters",
          "required_args",
          "command_template",
          "tool_groups",
          "fallback_outputs",
          "docs_anchor",
          "test_files",
          "fixtures"
        ],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "risk_level": {"type": "string", "enum": ["low", "medium", "high"]},
          "capabilities": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1},
          "tools_required": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1},
          "parameters": {"type": "object", "minProperties": 1},
          "required_args": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1},
          "optional_flags": {"type": "object"},
          "command_template": {"type": "string", "minLength": 1},
          "tool_groups": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string", "minLength": 1}
            }
          },
          "fallback_outputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["path_arg", "content"],
              "properties": {
                "path_arg": {"type": "string", "minLength": 1},
                "content": {"type": "string"}
              }
            }
          },
          "fallback_note": {"type": "string"},
          "docs_anchor": {"type": "string", "minLength": 1},
          "test_files": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1},
          "fixtures": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1},
          "sample_args": {"type": "object"}
        }
      }
    }
  }
}
