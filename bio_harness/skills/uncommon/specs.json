{
  "version": 1,
  "skills": [
    {
      "name": "methylation_bismark_style",
      "description": "Bismark-style bisulfite methylation analysis workflow with deterministic degrade behavior.",
      "risk_level": "medium",
      "capabilities": ["methylation_analysis", "alignment", "reference_inputs"],
      "tools_required": ["bismark"],
      "parameters": {
        "genome_folder": {"type": "path", "description": "Bismark genome folder.", "required": true},
        "reads_1": {"type": "path", "description": "Read 1 FASTQ.", "required": true},
        "reads_2": {"type": "path", "description": "Read 2 FASTQ.", "required": true},
        "output_dir": {"type": "path", "description": "Output directory.", "required": true},
        "output_report": {"type": "path", "description": "Output methylation summary TSV.", "required": true},
        "threads": {"type": "integer", "description": "Thread count.", "required": false, "default": 2},
        "sample_name": {"type": "string", "description": "Sample basename.", "required": false}
      },
      "required_args": ["genome_folder", "reads_1", "reads_2", "output_dir", "output_report"],
      "optional_flags": {
        "threads": "--parallel",
        "sample_name": "--basename"
      },
      "command_template": "mkdir -p {output_dir} && bismark --genome_folder {genome_folder} -1 {reads_1} -2 {reads_2} {optional_flags} -o {output_dir} && printf 'workflow\\tstatus\\nmethylation\\tcompleted\\n' > {output_report}",
      "tool_groups": [["bismark"]],
      "fallback_outputs": [
        {"path_arg": "output_report", "content": "workflow\tstatus\treason\nmethylation\tdegraded\tmissing_bismark\n"}
      ],
      "fallback_note": "Degrade safely when Bismark is unavailable.",
      "docs_anchor": "methylation-bismark-style",
      "test_files": [
        "tests/skills/test_uncommon_wrappers.py",
        "tests/workflows/test_uncommon_prompt_fixtures.py",
        "tests/core/test_uncommon_skill_ci_guardrails.py"
      ],
      "fixtures": ["tests/workflows/fixtures/uncommon_prompt_intents.json#methylation_basic"],
      "sample_args": {
        "genome_folder": "/refs/bismark_index",
        "reads_1": "/data/S1_R1.fastq.gz",
        "reads_2": "/data/S1_R2.fastq.gz",
        "output_dir": "/tmp/uncommon/methylation",
        "output_report": "/tmp/uncommon/methylation/report.tsv",
        "threads": 2,
        "sample_name": "sample1"
      }
    },
    {
      "name": "metagenomics_kraken2_bracken_style",
      "description": "Kraken2/Bracken-style metagenomics taxonomic profiling with deterministic command rendering.",
      "risk_level": "medium",
      "capabilities": ["metagenomics_profiling"],
      "tools_required": ["kraken2", "bracken"],
      "parameters": {
        "database": {"type": "path", "description": "Kraken2 database path.", "required": true},
        "reads_1": {"type": "path", "description": "Read 1 FASTQ.", "required": true},
        "reads_2": {"type": "path", "description": "Read 2 FASTQ.", "required": true},
        "output_dir": {"type": "path", "description": "Output directory.", "required": true},
        "output_report": {"type": "path", "description": "Bracken abundance report TSV.", "required": true},
        "threads": {"type": "integer", "description": "Thread count.", "required": false, "default": 2},
        "read_len": {"type": "integer", "description": "Estimated read length.", "required": false, "default": 150}
      },
      "required_args": ["database", "reads_1", "reads_2", "output_dir", "output_report"],
      "optional_flags": {
        "threads": "--threads"
      },
      "command_template": "mkdir -p {output_dir} && kraken2 --db {database} --paired {reads_1} {reads_2} {optional_flags} --report {output_dir}/kraken.report --output {output_dir}/kraken.out && bracken -d {database} -i {output_dir}/kraken.report -o {output_report} -r {read_len} -l S",
      "tool_groups": [["kraken2"], ["bracken"]],
      "fallback_outputs": [
        {"path_arg": "output_report", "content": "name\tfraction_total_reads\treason\nunclassified\t1.0\tmissing_kraken2_or_bracken\n"}
      ],
      "fallback_note": "Emit deterministic fallback abundance table when tools are missing.",
      "docs_anchor": "metagenomics-kraken2-bracken-style",
      "test_files": [
        "tests/skills/test_uncommon_wrappers.py",
        "tests/workflows/test_uncommon_prompt_fixtures.py",
        "tests/core/test_uncommon_skill_ci_guardrails.py"
      ],
      "fixtures": ["tests/workflows/fixtures/uncommon_prompt_intents.json#metagenomics_taxonomy"],
      "sample_args": {
        "database": "/refs/kraken_db",
        "reads_1": "/data/S1_R1.fastq.gz",
        "reads_2": "/data/S1_R2.fastq.gz",
        "output_dir": "/tmp/uncommon/metagenomics",
        "output_report": "/tmp/uncommon/metagenomics/bracken.tsv",
        "threads": 2,
        "read_len": 150
      }
    },
    {
      "name": "fusion_star_fusion_style",
      "description": "STAR-Fusion-style fusion transcript detection workflow.",
      "risk_level": "medium",
      "capabilities": ["fusion_detection", "alignment"],
      "tools_required": ["STAR-Fusion"],
      "parameters": {
        "genome_lib_dir": {"type": "path", "description": "STAR-Fusion CTAT genome lib directory.", "required": true},
        "reads_1": {"type": "path", "description": "Read 1 FASTQ.", "required": true},
        "reads_2": {"type": "path", "description": "Read 2 FASTQ.", "required": true},
        "output_dir": {"type": "path", "description": "Output directory.", "required": true},
        "output_report": {"type": "path", "description": "Fusion prediction TSV.", "required": true},
        "threads": {"type": "integer", "description": "Thread count.", "required": false, "default": 2}
      },
      "required_args": ["genome_lib_dir", "reads_1", "reads_2", "output_dir", "output_report"],
      "optional_flags": {
        "threads": "--CPU"
      },
      "command_template": "mkdir -p {output_dir} && STAR-Fusion --genome_lib_dir {genome_lib_dir} --left_fq {reads_1} --right_fq {reads_2} {optional_flags} --output_dir {output_dir} && cp {output_dir}/star-fusion.fusion_predictions.abridged.tsv {output_report}",
      "tool_groups": [["STAR-Fusion"]],
      "fallback_outputs": [
        {"path_arg": "output_report", "content": "fusion_name\tjunction_reads\tspanning_frags\treason\nNONE\t0\t0\tmissing_star_fusion\n"}
      ],
      "fallback_note": "Emit empty fusion report when STAR-Fusion is unavailable.",
