    {
      "name": "phylogenetics_iqtree_style",
      "description": "IQ-TREE-style phylogenetic inference from aligned sequence FASTA.",
      "risk_level": "medium",
      "capabilities": ["phylogenetics", "protein_analysis"],
      "tools_required": ["iqtree2"],
      "parameters": {
        "alignment_fasta": {"type": "path", "description": "Aligned sequence FASTA.", "required": true},
        "output_dir": {"type": "path", "description": "Output directory.", "required": true},
        "output_prefix": {"type": "path", "description": "Output prefix path.", "required": true},
        "output_tree": {"type": "path", "description": "Output Newick tree file.", "required": true},
        "model": {"type": "string", "description": "Substitution model.", "required": false, "default": "MFP"},
        "threads": {"type": "integer", "description": "Thread count.", "required": false, "default": 2},
        "seed": {"type": "integer", "description": "Deterministic seed.", "required": false, "default": 42}
      },
      "required_args": ["alignment_fasta", "output_dir", "output_prefix", "output_tree"],
      "optional_flags": {},
      "command_template": "mkdir -p {output_dir} && mkdir -p \"$(dirname {output_tree})\" && IQTREE_BIN=\"$(command -v iqtree2 || command -v iqtree)\" && OUT_PREFIX={output_prefix} && \"$IQTREE_BIN\" -s {alignment_fasta} -m {model} -nt {threads} -seed {seed} -redo -pre \"$OUT_PREFIX\" && cp \"$OUT_PREFIX.treefile\" {output_tree}",
      "tool_groups": [["iqtree2", "iqtree"]],
      "fallback_outputs": [
        {"path_arg": "output_tree", "content": "(placeholder:0.0);\n"}
      ],
      "fallback_note": "Emit deterministic one-tip Newick placeholder when IQ-TREE is unavailable.",
      "docs_anchor": "phylogenetics-iqtree-style",
      "test_files": [
        "tests/skills/test_uncommon_wrappers.py",
        "tests/workflows/test_uncommon_prompt_fixtures.py",
        "tests/core/test_uncommon_skill_ci_guardrails.py"
      ],
      "fixtures": ["tests/workflows/fixtures/uncommon_prompt_intents.json#phylogenetics_tree"],
      "sample_args": {
        "alignment_fasta": "/data/aligned.fasta",
        "output_dir": "/tmp/uncommon/phylo",
        "output_prefix": "/tmp/uncommon/phylo/tree",
        "output_tree": "/tmp/uncommon/phylo/tree.nwk",
        "model": "MFP",
        "threads": 2,
        "seed": 42
      }
    }
