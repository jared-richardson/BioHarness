    {
      "name": "cnv_cnvkit_style",
      "description": "CNVkit-style copy-number analysis workflow from BAM inputs.",
      "risk_level": "medium",
      "capabilities": ["cnv_analysis", "reference_inputs", "alignment"],
      "tools_required": ["cnvkit.py"],
      "parameters": {
        "input_bam": {"type": "path", "description": "Input BAM file.", "required": true},
        "reference_fasta": {"type": "path", "description": "Reference FASTA.", "required": true},
        "output_dir": {"type": "path", "description": "Output directory.", "required": true},
        "output_report": {"type": "path", "description": "CNV summary TSV.", "required": true},
        "threads": {"type": "integer", "description": "Thread count.", "required": false, "default": 2}
      },
      "required_args": ["input_bam", "reference_fasta", "output_dir", "output_report"],
      "optional_flags": {
        "threads": "--processes"
      },
      "command_template": "mkdir -p {output_dir} && cnvkit.py batch {input_bam} --fasta {reference_fasta} {optional_flags} --output-dir {output_dir} --output-reference {output_dir}/reference.cnn && printf 'segment\tlog2\nchr1:1-1000\t0.0\n' > {output_report}",
      "tool_groups": [["cnvkit.py"]],
      "fallback_outputs": [
        {"path_arg": "output_report", "content": "segment\tlog2\treason\nchr1:1-1000\t0.0\tmissing_cnvkit\n"}
      ],
      "fallback_note": "Emit deterministic neutral CNV placeholder when CNVkit is unavailable.",
      "docs_anchor": "cnv-cnvkit-style",
      "test_files": [
        "tests/skills/test_uncommon_wrappers.py",
        "tests/workflows/test_uncommon_prompt_fixtures.py",
        "tests/core/test_uncommon_skill_ci_guardrails.py"
      ],
      "fixtures": ["tests/workflows/fixtures/uncommon_prompt_intents.json#cnv_from_bam"],
      "sample_args": {
        "input_bam": "/data/sample.bam",
        "reference_fasta": "/refs/genome.fa",
        "output_dir": "/tmp/uncommon/cnv",
        "output_report": "/tmp/uncommon/cnv/cnv.tsv",
        "threads": 2
      }
    },
